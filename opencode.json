{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "permission": {
        "task": {
          "*": "deny",
          "general": "allow",
          "explore": "allow",
          "wow-reviewer": "ask"
        }
      }
    },
    "plan": {
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "rg *": "allow"
        }
      }
    }
  }
}
