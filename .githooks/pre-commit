#!/bin/sh
# pre-commit hook — wow-harness
#
# 一次性启用（clone 后跑一次）:
#   git config core.hooksPath .githooks
#
# 来源: 同步自 Towow 主仓 commit dff58afb (ADR/PLAN 编号唯一性)
# 设计: ADR-038 D11 schema-level 100% > prompt-level 70%
# 红线: ADR-041 v1.0 调字不加机制（grep 级 chokepoint 不算）

set -e

# H 系列编号唯一性预防：阻断同号 + 不同主题的 ADR/PLAN 命名冲突
NUMBERING_CHECK="$(git rev-parse --show-toplevel 2>/dev/null)/scripts/checks/check_adr_plan_numbering.py"
if [ -f "$NUMBERING_CHECK" ]; then
    if ! python3 "$NUMBERING_CHECK"; then
        exit 1
    fi
fi

exit 0
